<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0" />
            <geometry>
                <box size="0.4 0.4 0.1"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0" />
            <geometry>
                <box size="0.4 0.4 0.1"/>
            </geometry>
        </collision>
        <xacro:box_inertia  m="5.0" l="0.4" w="0.4" h="0.1"
                xyz="0 0 0.05" rpy="0 0 0" />
    </link>

    <link name="shoulder_link">
        <visual>
            <origin xyz="0 0 0.25" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.1" length="0.5"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.25" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.1" length="0.5"/>
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="1.0" r="0.1" l="0.5"
                xyz="0 0 0.25" rpy="0 0 0" />
    </link>

    <link name="arm_link">
        <visual>
            <origin xyz="0 0 0.3" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.05" length="0.6"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.3" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.05" length="0.6"/>
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="1.0" r="0.05" l="0.6"
                xyz="0 0 0.3" rpy="0 0 0" />
    </link>

    <link name="elbow_link">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.05" length="0.1"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.05" length="0.1"/>
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="1.0" r="0.04" l="0.1"
                xyz="0 0 0.05" rpy="0 0 0" />
    </link>

    <link name="forearm_link">
        <visual>
            <origin xyz="0 0 0.25" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.05" length="0.5"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.25" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.05" length="0.5"/>
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="1.0" r="0.05" l="0.5"
                xyz="0 0 0.25" rpy="0 0 0" />
    </link>

    <link name="wrist_link">
        <visual>
            <origin xyz="0 0 0.025" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.1 0.05"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.025" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.1 0.05"/>
            </geometry>
        </collision>
        <xacro:box_inertia  m="5.0" l="0.1" w="0.1" h="0.05"
                xyz="0 0 0.025" rpy="0 0 0" />
    </link>
    
    <link name="hand_link">
        <visual>
            <origin xyz="0 0 0.01" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.1 0.02"/>
            </geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.01" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.1 0.02"/>
            </geometry>
        </collision>
        <xacro:box_inertia  m="5.0" l="0.1" w="0.1" h="0.02"
                xyz="0 0 0.01" rpy="0 0 0" />
    </link>

    <link name="tool_link"/>



    <joint name="joint1" type="revolute">
        <parent link="base_link"/>
        <child link="shoulder_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" velocity="1.0" effort="1000.0"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </joint>

    <joint name="joint2" type="revolute">
        <parent link="shoulder_link"/>
        <child link="arm_link"/>
        <axis xyz="0 1 0"/>
        <limit lower="0.0" upper="2.5" velocity="1.0" effort="1000.0"/>
        <origin xyz="0 0 0.5" rpy="0 0 0"/>
    </joint>
    
     <joint name="joint3" type="revolute">
        <parent link="arm_link"/>
        <child link="elbow_link"/>
        <axis xyz="0 1 0"/>
        <limit lower="0.0" upper="2.5" velocity="1.0" effort="1000.0"/>
        <origin xyz="0 0 0.6" rpy="0 0 0"/>
    </joint>

    <joint name="joint4" type="revolute">
        <parent link="elbow_link"/>
        <child link="forearm_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" velocity="1.0" effort="1000.0"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </joint>

    <joint name="joint5" type="revolute">
        <parent link="forearm_link"/>
        <child link="wrist_link"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" velocity="1.0" effort="1000.0"/>
        <origin xyz="0 0 0.5" rpy="0 0 0"/>
    </joint>

    <joint name="joint6" type="continuous">
        <parent link="wrist_link"/>
        <child link="hand_link"/>
        <axis xyz="0 0 1"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </joint>

    <joint name="hand_tool_joint" type="fixed">
        <parent link="hand_link"/>
        <child link="tool_link"/>
        <origin xyz="0.0 0.0 0.02" rpy="0.0 0.0 0.0"/>
    </joint>


</robot>
